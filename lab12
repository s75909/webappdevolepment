DATABASE SETUP

CREATE DATABASE drivesmart_db;

USE drivesmart_db;

CREATE TABLE Training_Sessions (
  session_id INT AUTO_INCREMENT PRIMARY KEY,
  student_name VARCHAR(100),
  branch_location VARCHAR(100),
  lesson_type VARCHAR(50),
  status VARCHAR(20)
);

